# my-terminal Brewfile — 跨平台 CLI 工具
# Usage: brew bundle --file=Brewfile

# Shell & Prompt
brew "starship"
brew "zsh"

# Fuzzy finder & Navigation
brew "fzf"
brew "zoxide"

# Modern CLI replacements
brew "eza"        # ls → eza
brew "bat"        # cat → bat
brew "fd"         # find → fd
brew "ripgrep"    # grep → rg
brew "delta"      # diff → delta

# Utilities
brew "jq"
brew "tldr"
brew "tmux"

# Dotfile manager
brew "chezmoi"
