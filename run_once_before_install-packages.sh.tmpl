{{- /* chezmoi 首次 apply 时自动安装依赖 */ -}}
#!/usr/bin/env bash
set -euo pipefail

echo "── 安装依赖包 ──────────────────────────────"

# ─── Ensure Homebrew is available ────────────────────────
if ! command -v brew &>/dev/null; then
    echo "安装 Homebrew..."
    NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
{{- if eq .chezmoi.os "darwin" }}
{{-   if eq .chezmoi.arch "arm64" }}
    eval "$(/opt/homebrew/bin/brew shellenv)"
{{-   else }}
    eval "$(/usr/local/bin/brew shellenv)"
{{-   end }}
{{- else }}
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
{{- end }}
fi

# ─── CLI tools via Brewfile ──────────────────────────────
echo "安装 CLI 工具 (brew bundle)..."
CHEZMOI_SOURCE="$(chezmoi source-path)"
brew bundle --no-lock --file="${CHEZMOI_SOURCE}/Brewfile"

# ─── Platform-specific packages ──────────────────────────
{{- if eq .chezmoi.os "darwin" }}
echo "安装 macOS 应用..."
brew install --cask ghostty 2>/dev/null || true
brew install --cask font-jetbrains-mono-nerd-font 2>/dev/null || true
{{- else }}
echo "安装 Nerd Font (Linux)..."
FONT_DIR="$HOME/.local/share/fonts"
mkdir -p "$FONT_DIR"
if [[ ! -f "$FONT_DIR/JetBrainsMonoNerdFont-Regular.ttf" ]]; then
    FONT_URL="https://github.com/ryanoasis/nerd-fonts/releases/latest/download/JetBrainsMono.tar.xz"
    echo "下载 JetBrainsMono Nerd Font..."
    curl -fsSL "$FONT_URL" | tar -xJ -C "$FONT_DIR"
    fc-cache -fv "$FONT_DIR" >/dev/null 2>&1
fi
{{- end }}

# ─── Zinit ───────────────────────────────────────────────
ZINIT_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}/zinit/zinit.git"
if [[ ! -d "$ZINIT_HOME" ]]; then
    echo "安装 zinit..."
    mkdir -p "$(dirname "$ZINIT_HOME")"
    git clone https://github.com/zdharma-continuum/zinit.git "$ZINIT_HOME"
fi

echo "── 依赖安装完成 ────────────────────────────"
