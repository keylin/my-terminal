{{- /* chezmoi 配置模板 — 首次 init 时交互式填写 */ -}}

{{- /* GitHub 用户名：优先自动获取，失败则提示手动输入 */ -}}
{{- $github_user := "" -}}
{{- if (output "sh" "-c" "gh api user --jq .login 2>/dev/null || true" | trim) -}}
{{-   $github_user = output "sh" "-c" "gh api user --jq .login 2>/dev/null || true" | trim -}}
{{- else if (output "sh" "-c" "git config --global user.name 2>/dev/null || true" | trim) -}}
{{-   $github_user = output "sh" "-c" "git config --global user.name 2>/dev/null || true" | trim -}}
{{- end -}}
{{- if eq $github_user "" -}}
{{-   $github_user = promptStringOnce . "github_user" "GitHub 用户名" -}}
{{- end -}}

{{- $proxy_port := promptStringOnce . "proxy_port" "代理端口 (如 1080，留空跳过)" -}}

[data]
    github_user = {{ $github_user | quote }}
    proxy_port = {{ $proxy_port | quote }}
