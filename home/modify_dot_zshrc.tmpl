{{- /* modify_dot_zshrc.tmpl — merge managed block with user content */ -}}
#!/bin/bash
set -euo pipefail

START_MARKER='# >>> chezmoi managed start >>>'
END_MARKER='# <<< chezmoi managed end <<<'

# ─── Managed content (Go templates already rendered by chezmoi) ────
MANAGED_BLOCK=$(cat <<'MANAGED_EOF'
# ─── Zinit (managed by chezmoi externals) ────────────────
ZINIT_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}/zinit/zinit.git"
source "${ZINIT_HOME}/zinit.zsh"

# ─── Zinit Plugins ──────────────────────────────────────
zinit light zsh-users/zsh-syntax-highlighting
zinit light zsh-users/zsh-autosuggestions
zinit light zsh-users/zsh-completions
zinit light Aloxaf/fzf-tab

# Load completions
autoload -Uz compinit && compinit
zinit cdreplay -q

# ─── History ─────────────────────────────────────────────
HISTSIZE=10000
SAVEHIST=10000
HISTFILE=~/.zsh_history
setopt appendhistory sharehistory
setopt hist_ignore_space hist_ignore_all_dups hist_save_no_dups

# ─── Completion styling ─────────────────────────────────
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Za-z}'
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"
zstyle ':completion:*' menu no
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'eza -1 --color=always $realpath'
zstyle ':fzf-tab:complete:__zoxide_z:*' fzf-preview 'eza -1 --color=always $realpath'

# ─── Aliases (cross-platform) ───────────────────────────
alias ls='eza --color=always --icons=always'
alias ll='eza -la --color=always --icons=always'
alias lt='eza -T --color=always --icons=always --level=2'
alias cat='bat --paging=never'
alias grep='rg'
alias find='fd'

# ─── Proxy ───────────────────────────────────────────────
{{ if .proxy_port -}}
alias proxys5='export ALL_PROXY=socks5://127.0.0.1:{{ .proxy_port }}'
alias unproxys5='unset ALL_PROXY'
alias proxyhttp='export HTTP_PROXY=http://127.0.0.1:{{ .proxy_port }}; export HTTPS_PROXY=http://127.0.0.1:{{ .proxy_port }}'
alias unproxyhttp='unset HTTP_PROXY HTTPS_PROXY'
{{ end -}}

# ─── PATH ────────────────────────────────────────────────
export PATH="$HOME/.local/bin:$PATH"
{{- if eq .chezmoi.os "darwin" }}
# macOS: openjdk
{{-   if eq .chezmoi.arch "arm64" }}
export PATH="/opt/homebrew/opt/openjdk/bin:$PATH"
{{-   else }}
export PATH="/usr/local/opt/openjdk/bin:$PATH"
{{-   end }}
{{- end }}

# ─── Docker completions ─────────────────────────────────
if [[ -d "$HOME/.docker/completions" ]]; then
    fpath=($HOME/.docker/completions $fpath)
fi
{{- if eq .chezmoi.os "darwin" }}

# ─── macOS only ──────────────────────────────────────────
# Antigravity
export PATH="$HOME/.antigravity/antigravity/bin:$PATH"

# Wrapper: unlock keychain before running claude (SSH sessions)
claude() {
    if [[ -n "${SSH_CONNECTION:-}" && -z "${KEYCHAIN_UNLOCKED:-}" ]]; then
        security unlock-keychain ~/Library/Keychains/login.keychain-db
        export KEYCHAIN_UNLOCKED=true
    fi
    command claude "$@"
}
{{- end }}

# ─── Key bindings ─────────────────────────────────────────
bindkey '^[[3~' delete-char          # Delete
bindkey '^[[H'  beginning-of-line    # Home
bindkey '^[[F'  end-of-line          # End

# ─── Tool init (cross-platform) ─────────────────────────
eval "$(starship init zsh)"
eval "$(fzf --zsh)"
eval "$(zoxide init --cmd cd zsh)"

# ─── User local overrides (不受 chezmoi 管理) ──────────
[[ -f ~/.zshrc.local ]] && source ~/.zshrc.local
MANAGED_EOF
)

# ─── Read current file from stdin ─────────────────────────
CURRENT=$(cat)

if [[ -z "$CURRENT" ]]; then
    # ── Case 1: Fresh install (no existing .zshrc) ────────
    echo "$START_MARKER"
    echo "$MANAGED_BLOCK"
    echo "$END_MARKER"
    echo ""
    echo "# ─── Your customizations below (not managed by chezmoi) ──"

elif [[ "$CURRENT" == *"$START_MARKER"* ]] && [[ "$CURRENT" == *"$END_MARKER"* ]]; then
    # ── Case 3: Subsequent apply (both markers present) ───
    # Replace content between markers; preserve everything else
    export MANAGED_BLOCK
    printf '%s\n' "$CURRENT" | awk -v start="$START_MARKER" -v end="$END_MARKER" '
    BEGIN { in_managed = 0; replaced = 0 }
    {
        if (!replaced && index($0, start) == 1) {
            in_managed = 1
            print start
            printf "%s\n", ENVIRON["MANAGED_BLOCK"]
            next
        }
        if (in_managed && index($0, end) == 1) {
            in_managed = 0
            replaced = 1
            print end
            next
        }
        if (!in_managed) print
    }'

else
    # ── Case 2: First migration (content but no markers) ──
    echo "$START_MARKER"
    echo "$MANAGED_BLOCK"
    echo "$END_MARKER"
    echo ""
    echo "$CURRENT"
fi
