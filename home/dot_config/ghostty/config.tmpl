{{- /* ~/.config/ghostty/config */ -}}

# ─── Terminal ─────────────────────────────────────────────
# 使用 xterm-256color 保证 SSH 到远端时的兼容性 (与 iTerm2 一致)
term = xterm-256color

# ─── Font ────────────────────────────────────────────────
font-family = SF Mono
font-size = 12
font-thicken = true
# CJK 字符指定统一字体，避免回退时大小不一
font-codepoint-map = U+4E00-U+9FFF=Hiragino Sans GB
font-codepoint-map = U+3400-U+4DBF=Hiragino Sans GB
font-codepoint-map = U+F900-U+FAFF=Hiragino Sans GB
font-codepoint-map = U+3000-U+303F=Hiragino Sans GB
font-codepoint-map = U+FF00-U+FFEF=Hiragino Sans GB

# ─── Theme: Catppuccin Mocha ─────────────────────────────
palette = 0=#45475a
palette = 1=#f38ba8
palette = 2=#a6e3a1
palette = 3=#f9e2af
palette = 4=#89b4fa
palette = 5=#f5c2e7
palette = 6=#94e2d5
palette = 7=#a6adc8
palette = 8=#585b70
palette = 9=#f38ba8
palette = 10=#a6e3a1
palette = 11=#f9e2af
palette = 12=#89b4fa
palette = 13=#f5c2e7
palette = 14=#94e2d5
palette = 15=#bac2de
background = 1e1e2e
foreground = cdd6f4
cursor-color = f5e0dc
cursor-text = 11111b
selection-background = 353749
selection-foreground = cdd6f4

# ─── Cursor ──────────────────────────────────────────────
cursor-style = bar
cursor-style-blink = true

# ─── Clipboard ──────────────────────────────────────────
copy-on-select = clipboard
clipboard-trim-trailing-spaces = true
clipboard-paste-protection = false

# ─── Quick Terminal ─────────────────────────────────────
keybind = global:cmd+grave_accent=toggle_quick_terminal
quick-terminal-position = center
quick-terminal-size = 50%,60%
quick-terminal-animation-duration = 0.15

# ─── Display ────────────────────────────────────────────
background-opacity = 0.9
mouse-hide-while-typing = true
resize-overlay = after-first

# ─── Scrollback ──────────────────────────────────────────
scrollback-limit = 10000
scroll-on-output = false

# ─── Window ──────────────────────────────────────────────
window-padding-x = 4
window-padding-y = 4
confirm-close-surface = false
quit-after-last-window-closed = true
window-save-state = always

# ─── Split ──────────────────────────────────────────────
unfocused-split-opacity = 0.65
unfocused-split-fill = #1e1e2e
focus-follows-mouse = true


# ─── macOS only (.chezmoiignore 已确保此文件仅 macOS 生效) ──
macos-titlebar-style = hidden
macos-option-as-alt = true
